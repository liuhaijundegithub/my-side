{
  "name": "my-site",
  "version": "1.0.0",
  "description": "unisolution前端基于react + vite的开发模板 ",
  "main": "index.js",
  "author": "unisolution frontend team",
  "license": "MIT",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/ali-oss": "^6.16.11",
    "@types/crypto-js": "^4.2.2",
    "@types/lodash": "^4.17.16",
    "@types/md5": "^2.3.5",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-legacy": "^6.0.2",
    "@vitejs/plugin-react": "^4.4.0",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.4",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "less": "^4.2.2",
    "lint-staged": "^15.5.0",
    "postcss-preset-env": "^10.1.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "vite": "^6.2.2"
  },
  "scripts": {
    "dev": "vite --host --mode development",
    "build": "vite build --mode production",
    "pre-commit": "lint-staged",
    "prepare": "husky && echo pnpm pre-commit > .husky/pre-commit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "build:dev": "vite build --mode development",
    "lintfix": "eslint --fix . --ext ts,tsx",
    "preview": "vite preview --host 0.0.0.0 --port 1070"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.23.0",
    "@ant-design/icons": "^6.0.0",
    "ahooks": "^3.8.4",
    "ali-oss": "^6.22.0",
    "antd": "^5.26.4",
    "axios": "^1.8.4",
    "classnames": "^2.5.1",
    "compressorjs": "^1.2.1",
    "core-js": "^3.43.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.13",
    "lodash": "^4.17.21",
    "md5": "^2.3.0",
    "mobile-detect": "^1.4.5",
    "navyd": "^1.1.6",
    "nprogress": "^0.2.0",
    "react": "18",
    "react-dom": "18",
    "react-router-dom": "^7.4.0",
    "regenerator-runtime": "^0.14.1",
    "uuid": "^11.1.0",
    "zustand": "^5.0.8"
  },
  "lint-staged": {
    "src/**/*.{ts,js,vue,tsx,jsx}": [
      "eslint --quiet"
    ]
  },
  "pnpm": {
    "overrides": {}
  }
}
